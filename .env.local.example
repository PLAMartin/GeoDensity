# Supabase (server-side only — never expose the service-role key to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Plausible analytics (leave unset to disable analytics entirely)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Public site URL, used for metadata and Open Graph tags
NEXT_PUBLIC_SITE_URL=https://geodensity.net
